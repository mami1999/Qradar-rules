{
  "name": "QRadar-0010 - Cryptocurrency Mining Activity Detection",
  "description": "Detects unauthorized cryptocurrency mining (cryptojacking) by identifying network connections to known mining pool ports. Cryptomining malware consumes resources and often indicates a broader compromise.",
  "type": "FLOW",
  "enabled": true,
  "severity": 7,
  "credibility": 4,
  "relevance": 4,
  "category": "Impact / Resource Hijacking",
  "mitre": {
    "tactic": "TA0040",
    "tactic_name": "Impact",
    "technique": "T1496",
    "technique_name": "Resource Hijacking"
  },
  "detection": {
    "log_source_type": "Network Flows (QFlow), DNS Logs, Proxy Logs, Firewall",
    "event_name_filter": "Stratum Protocol, Mining Pool Connection",
    "aql": "SELECT sourceIP, destinationIP, destinationPort, COUNT(*) as connection_count FROM flows WHERE destinationPort IN (3333, 4444, 5555, 7777, 8888, 9999, 14444, 14433, 45700) GROUP BY sourceIP, destinationIP, destinationPort HAVING COUNT(*) >= 5 LAST 30 MINUTES",
    "threshold_connections": 5,
    "time_window_seconds": 1800,
    "group_by": "sourceIP",
    "known_mining_ports": [3333, 4444, 5555, 7777, 8888, 9999, 14444, 14433, 45700]
  },
  "response": {
    "create_offense": true,
    "offense_name": "Cryptocurrency Mining Activity from {sourceIP}",
    "offense_description": "A host is communicating with known cryptocurrency mining pool ports. Indicates unauthorized cryptojacking, often following a system compromise.",
    "email_notification": true,
    "syslog_output": true,
    "offense_type": "Source IP",
    "recommended_action": "Isolate affected host, perform full malware scan, investigate initial access vector"
  },
  "tags": ["cryptojacking", "crypto-mining", "monero", "stratum", "resource-hijacking", "malware"],
  "notes": "Port-based detection using common Stratum protocol ports. Mining pool ports list should be updated regularly.",
  "version": "1.2",
  "author": "Security Team",
  "created": "2026-06-27"
}
