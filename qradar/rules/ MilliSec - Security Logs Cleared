{
  "name": "QRadar-0006 - Windows Privilege Escalation Detection",
  "description": "Detects privilege escalation attempts on Windows systems by monitoring for suspicious activities indicative of UAC bypass, group membership changes, and elevation tool usage.",
  "type": "EVENT",
  "enabled": true,
  "severity": 9,
  "credibility": 4,
  "relevance": 5,
  "category": "Privilege Escalation",
  "mitre": {
    "tactic": "TA0004",
    "tactic_name": "Privilege Escalation",
    "technique": "T1548.002",
    "technique_name": "Abuse Elevation Control Mechanism: Bypass User Account Control"
  },
  "detection": {
    "log_source_type": "Windows Security Event Log, Sysmon",
    "event_name_filter": "Group membership change, Special logon, UAC bypass",
    "aql": "SELECT sourceIP, username, COUNT(*) as event_count FROM events WHERE LOGSOURCETYPENAME(devicetype) ILIKE '%windows%' AND (UTF8(payload) ILIKE '%bypassuac%' OR UTF8(payload) ILIKE '%runas%' OR UTF8(payload) ILIKE '%whoami /priv%' OR UTF8(payload) ILIKE '%net localgroup administrators%' OR UTF8(payload) ILIKE '%added to%' OR UTF8(payload) ILIKE '%privilege%') GROUP BY sourceIP, username HAVING COUNT(*) >= 1 LAST 15 MINUTES",
    "threshold": 1,
    "time_window_seconds": 900,
    "group_by": "username, sourceIP"
  },
  "response": {
    "create_offense": true,
    "offense_name": "Privilege Escalation Attempt by {username}",
    "offense_description": "Suspicious privilege escalation activity detected. User may have attempted UAC bypass or been added to a privileged group.",
    "email_notification": true,
    "syslog_output": true,
    "offense_type": "Username"
  },
  "tags": ["privilege-escalation", "uac-bypass", "windows", "admin-group", "sysmon"],
  "notes": "Uses UTF8(payload) keyword matching for maximum QRadar version compatibility. Detects common escalation tool signatures.",
  "version": "1.2",
  "author": "Security Team",
  "created": "2026-06-27"
}
